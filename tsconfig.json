{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": "./src",
    "resolveJsonModule": true,
    "allowJs": true,
    "paths": {
      "@components/*": ["components/*"],
      "@services/*": ["services/*"],
      "@utils/*": ["utils/*"],
      "@constants/*": ["constants/*"],
      "@engine/*": ["engine/*"],
      "@runtime/*": ["runtime/*"],
      "@extraction/*": ["extraction/*"],
      "@pacing/*": ["pacing/*"],
      "@generation/*": ["generation/*"],
      "@memory/*": ["memory/*"],
      "@copilot/*": ["copilot/*"]
    }
  },
  "include": ["src/index.tsx", "src/engine/**/*.ts", "src/extraction/**/*.ts", "src/runtime/**/*.ts", "src/pacing/**/*.ts", "src/generation/**/*.ts", "src/services/**/*.ts", "src/utils/**/*.ts", "src/constants/**/*.ts", "src/memory/**/*.ts", "src/studio/**/*.ts", "src/studio/**/*.tsx", "src/copilot/**/*.ts", "src/components/**/*.ts", "src/components/**/*.tsx", "global.d.ts"],
  "exclude": ["src/**/*.test.ts"]
}
