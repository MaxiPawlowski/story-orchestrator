{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": "./src",
    "resolveJsonModule": true,
    "allowJs": true,
    "paths": {
      "@components/*": ["components/*"],
      "@services/*": ["services/*"],
      "@hooks/*": ["hooks/*"],
      "@utils/*": ["utils/*"],
      "@controllers/*": ["controllers/*"],
      "@constants/*": ["constants/*"],
      "@store/*": ["store/*"],
      "@engine/*": ["engine/*"],
      "@runtime/*": ["runtime/*"]
    }
  },
  "include": ["src/index.tsx", "src/engine/**/*.ts", "src/runtime/**/*.ts", "src/services/**/*.ts", "src/utils/**/*.ts", "src/constants/**/*.ts", "global.d.ts"],
  "exclude": ["src/**/*.test.ts"]
}
