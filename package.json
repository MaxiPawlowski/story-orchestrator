{
  "name": "extension-template",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "cytoscape": "^3.28.1",
    "cytoscape-dagre": "^2.5.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "yaml": "^2.8.2",
    "zustand": "^5.0.8"
  },
  "scripts": {
    "build": "webpack --mode production",
    "start": "npm run dev",
    "dev": "cross-env NODE_ENV=development concurrently \"webpack --mode development --watch\" \"tsc --noEmit --watch\"",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build --output-dir .sb-static"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.24.0",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react-webpack5": "^8.6.14",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/cytoscape-dagre": "^2.3.4",
    "@types/jest": "^30.0.0",
    "@types/jquery": "^3.5.33",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "eslint": "^8.57.1",
    "eslint-plugin-jsdoc": "^61.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "postcss-preset-env": "^10.3.1",
    "storybook": "^8.6.14",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.1.13",
    "terser-webpack-plugin": "^5.3.10",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.0",
    "webpack-cli": "^5.1.4",
    "webpack-livereload-plugin": "^3.0.2",
    "playwright": "^1.52.0"
  }
}
